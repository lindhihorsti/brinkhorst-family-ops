# Kopieren nach infra/.env.dev — Secrets NUR für die lokale DEV/TEST-Instanz.
# DENNIS_PWHASH: eigenes Dev-Passwort, z.B.:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'dev-local-password'
DENNIS_PWHASH=
# Telegram in DEV bewusst leer lassen (den Webhook besitzt PROD)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWLIST=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_ACTIVITIES=gpt-5.2
OPENAI_TIMEOUT_SECONDS=90
